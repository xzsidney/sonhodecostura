<?xml version="1.0"?>
<ruleset>
    <arg name="basepath" value="."/>
    <arg name="extensions" value="php"/>
    <arg name="parallel" value="80"/>
    <arg name="cache" value=".phpcs-cache"/>
    <arg name="colors"/>

    <!-- Ignore warnings, show progress of the run and show sniff names -->
    <arg value="nps"/>

    <!-- Directories to be checked -->
    <file>src</file>
    <file>tests/unit</file>
    <file>tests/functional</file>

    <!-- Include full Unleashed Coding Standard -->
    <rule ref="Unleashed"/>

    <!-- PHPUnit's @dataProvider annotation isn't a class reference, so don't try to resolve it against
         the imported DataProvider attribute class (which differs only by case) -->
    <rule ref="SlevomatCodingStandard.Namespaces.UnusedUses">
        <properties>
            <property name="ignoredAnnotations" type="array">
                <element value="@dataProvider"/>
            </property>
        </properties>
    </rule>
</ruleset>
